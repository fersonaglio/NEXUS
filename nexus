#!/usr/bin/env bun

// NEXUS Wrapper - Run OpenCode with Ollama as default local provider

import { spawn } from "bun"
import { readFileSync, writeFileSync, existsSync, mkdirSync } from "fs"
import { join, dirname } from "path"
import { homedir } from "os"

const NEXUS_CONFIG_DIR = join(homedir(), ".config", "nexus")
const NEXUS_CONFIG_FILE = join(NEXUS_CONFIG_DIR, "config.json")

// Default NEXUS config - Ollama local
const defaultConfig = {
  provider: {
    ollama: {
      api: "http://localhost:11434/v1",
      default_model: "qwen2.5-coder:7b-instruct",
    }
  },
  default_model: "ollama/qwen2.5-coder:7b-instruct",
  model: "ollama/qwen2.5-coder:7b-instruct"
}

// Ensure NEXUS config exists
if (!existsSync(NEXUS_CONFIG_FILE)) {
  if (!existsSync(NEXUS_CONFIG_DIR)) {
    mkdirSync(NEXUS_CONFIG_DIR, { recursive: true })
  }
  writeFileSync(NEXUS_CONFIG_FILE, JSON.stringify(defaultConfig, null, 2))
  console.log("Created NEXUS config at:", NEXUS_CONFIG_FILE)
}

// Parse command line args
const args = process.argv.slice(2)

// Check for --model flag and prepend "ollama/" if just model name
const processedArgs = args.map(arg => {
  if (arg.startsWith("--model=") || arg.startsWith("-m=")) {
    const model = arg.split("=")[1]
    if (!model.includes("/")) {
      return arg.replace(model, `ollama/${model}`)
    }
  }
  return arg
})

// Pass through all args to opencode
const exitCode = await spawn({
  cmd: ["bun", "run", "--cwd", join(import.meta.dir, ".."), "packages/opencode/src/index.ts", ...processedArgs],
  stdio: "inherit"
})

process.exit(exitCode)
